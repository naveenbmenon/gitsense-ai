{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["python311", "pip"]
        },
        "install": {
          "cmds": ["pip install -r requirements.txt"]
        }
      },
      "start": {
        "cmd": "python3 -m celery -A app.celery.celery_app.celery_app worker --loglevel=info"
      }
    }
  }
}